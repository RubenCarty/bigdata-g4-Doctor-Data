# Caddyfile de QA — esta es la copia que realmente se usa: se copia dentro de la imagen de
# este mismo repo (Dockerfile, stage "qa") y es la que sirve el build estático + reenvía
# /api/* a la API. Existe una copia espejo en doctordata-backend-go/deploy/qa/Caddyfile solo
# para tener la infra de QA versionada junto al resto del compose — si tocas una, toca la otra.
qa.mydoctordata.net {
	encode gzip

	handle_path /api/* {
		reverse_proxy api:8080
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		-Server
	}
}
